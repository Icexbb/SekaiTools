<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SekaiToolsMauiText.View.Translate.Components.TranslateLineEffect">
    <Grid ColumnDefinitions="140,*" HeightRequest="48" Margin="2,2,2,0">

        <!-- Location Icon Panel -->
        <Border Grid.Column="0"
                Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                StrokeThickness="1" StrokeShape="RoundRectangle 6"
                Margin="0,0,3,0" Padding="4">
            <Label Text="📍" FontSize="16"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Border>

        <!-- Content Panel -->
        <Border Grid.Column="1"
                Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
                StrokeThickness="1" StrokeShape="RoundRectangle 6"
                Padding="6,2">
            <Grid ColumnDefinitions="*,32,*">

                <!-- Original Content -->
                <Label Grid.Column="0"
                       Text="{Binding OriginalContent}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="13" />

                <!-- Arrow -->
                <Label Grid.Column="1"
                       Text="→"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="14" />

                <!-- Translated Content -->
                <Entry Grid.Column="2"
                       Text="{Binding TranslatedContent, Mode=TwoWay}"
                       Placeholder="{Binding OriginalContent}"
                       HorizontalOptions="Fill"
                       VerticalOptions="Center"
                       HorizontalTextAlignment="Center"
                       FontSize="13"
                       ClearButtonVisibility="Never" />
            </Grid>
        </Border>
    </Grid>
</ContentView>

