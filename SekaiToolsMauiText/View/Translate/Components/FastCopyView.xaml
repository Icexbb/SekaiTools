<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SekaiToolsMauiText.View.Translate.Components.FastCopyView">
    <Border Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#555555}"
            StrokeThickness="1" StrokeShape="RoundRectangle 6"
            Padding="6">
        <ScrollView VerticalScrollBarVisibility="Always">
            <VerticalStackLayout Spacing="4">
                <Label Text="特殊字符" HorizontalOptions="Center" FontAttributes="Bold" FontSize="13" />

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                    <Button Grid.Row="0" Grid.Column="0" Text="【】" Clicked="OnSpecialCharClicked" Margin="2" />
                    <Button Grid.Row="0" Grid.Column="1" Text="「」" Clicked="OnSpecialCharClicked" Margin="2" />
                    <Button Grid.Row="1" Grid.Column="0" Text="『』" Clicked="OnSpecialCharClicked" Margin="2" />
                    <Button Grid.Row="1" Grid.Column="1" Text="《》" Clicked="OnSpecialCharClicked" Margin="2" />
                    <Button Grid.Row="2" Grid.Column="0" Text="（）" Clicked="OnSpecialCharClicked" Margin="2" />
                    <Button Grid.Row="2" Grid.Column="1" Text="“”" Clicked="OnSpecialCharClicked" Margin="2" />
                    <Button Grid.Row="3" Grid.Column="0" Text="~" Clicked="OnSpecialCharClicked" Margin="2" />
                    <Button Grid.Row="3" Grid.Column="1" Text="♪" Clicked="OnSpecialCharClicked" Margin="2" />
                    <Button Grid.Row="4" Grid.Column="0" Text="☆" Clicked="OnSpecialCharClicked" Margin="2" />
                    <Button Grid.Row="4" Grid.Column="1" Text="——" Clicked="OnSpecialCharClicked" Margin="2" />
                </Grid>

                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light=#DDDDDD, Dark=#444444}"
                         Margin="0,4" />

                <Button Text="添加自定义" Clicked="OnAddCustomClicked"
                        HorizontalOptions="Fill" />

                <VerticalStackLayout x:Name="CustomCharsPanel" Spacing="2" />
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</ContentView>

