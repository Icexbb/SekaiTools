<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <LangVersion>default</LangVersion>
        <Nullable>enable</Nullable>
        <RootNamespace>SekaiToolsCore</RootNamespace>
        <Configurations>Debug;Release</Configurations>
        <Platforms>AnyCPU;x64</Platforms>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Emgu.CV" Version="4.13.0.5924" />
        <PackageReference Include="Emgu.CV.runtime.windows" Version="4.13.0.5924" Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
        <PackageReference Include="Emgu.CV.runtime.macos" Version="4.13.0.5924" Condition="$([MSBuild]::IsOSPlatform('OSX'))" />
        <PackageReference Include="Emgu.CV.runtime.ubuntu" Version="4.13.0.5924" Condition="$([MSBuild]::IsOSPlatform('Linux'))" />
        <PackageReference Include="SkiaSharp" Version="3.119.2" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\SekaiToolsBase\SekaiToolsBase.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <Folder Include="Match\"/>
    </ItemGroup>

</Project>
