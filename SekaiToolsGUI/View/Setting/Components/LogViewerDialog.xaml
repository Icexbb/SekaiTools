<ui:ContentDialog
    x:Class="SekaiToolsGUI.View.Setting.Components.LogViewerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:components="clr-namespace:SekaiToolsGUI.View.Setting.Components"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Title="运行日志" MinWidth="680" MinHeight="400" DialogWidth="680"
    CloseButtonText="关闭">
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type components:LogViewerDialog}" />
    </ui:ContentDialog.Resources>
    <ui:ContentDialog.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ListBox x:Name="LogListBox" Grid.Row="0"
                     Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                     BorderThickness="0"
                     FontFamily="Consolas" FontSize="11"
                     HorizontalContentAlignment="Stretch" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                <ui:Button Content="清空日志" Click="ClearLog_Click" Margin="0,0,8,0" />
            </StackPanel>
        </Grid>
    </ui:ContentDialog.Content>
</ui:ContentDialog>
