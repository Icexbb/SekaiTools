<ui:ContentDialog
    x:Class="SekaiToolsGUI.View.Setting.Components.LogViewerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:components="clr-namespace:SekaiToolsGUI.View.Setting.Components"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Title="运行日志" MinWidth="700" MinHeight="450" DialogWidth="700"
    CloseButtonText="关闭">
    <ui:ContentDialog.Resources>
        <Style BasedOn="{StaticResource {x:Type ui:ContentDialog}}"
               TargetType="{x:Type components:LogViewerDialog}" />
    </ui:ContentDialog.Resources>
    <ui:ContentDialog.Content>
        <DockPanel>
            <Border DockPanel.Dock="Top" Margin="0,0,0,8">
                <DockPanel>
                    <ui:Button DockPanel.Dock="Right" Content="清空日志" Click="ClearLog_Click" />
                    <ui:TextBlock Text="等级:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox x:Name="LevelFilter" Width="100" SelectedIndex="0"
                              SelectionChanged="LevelFilter_SelectionChanged">
                        <ComboBoxItem>全部</ComboBoxItem>
                        <ComboBoxItem>INFO+</ComboBoxItem>
                        <ComboBoxItem>WARN+</ComboBoxItem>
                        <ComboBoxItem>ERROR+</ComboBoxItem>
                    </ComboBox>
                </DockPanel>
            </Border>

            <ListBox x:Name="LogListBox"
                     Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                     BorderThickness="0"
                     FontFamily="Consolas" FontSize="11"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </ui:ContentDialog.Content>
</ui:ContentDialog>
