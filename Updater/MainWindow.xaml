<Window x:Class="Updater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ResizeMode="CanResize"
        Title="更新程序" Height="200" Width="400"
        MinHeight="200" MinWidth="400">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <TextBlock x:Name="StatusText" Text="正在检查更新..." TextWrapping="WrapWithOverflow"
                       HorizontalAlignment="Stretch" TextAlignment="Center" VerticalAlignment="Center"/>
        </ScrollViewer>
        <ProgressBar x:Name="Progress" Grid.Row="1" Height="20" Minimum="0" Maximum="100"/>
    </Grid>
</Window>